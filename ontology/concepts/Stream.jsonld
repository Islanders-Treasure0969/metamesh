{
  "@context": {
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "@base": "https://metamesh.dev/ontology/",
    "dv": "https://metamesh.dev/ext/dv/"
  },
  "@id": "Stream",
  "@type": "skos:Concept",
  "skos:prefLabel": [
    {
      "@language": "ja",
      "@value": "配信"
    },
    {
      "@language": "en",
      "@value": "Stream"
    }
  ],
  "skos:definition": [
    {
      "@language": "ja",
      "@value": "Channel 上で行われる 1 回の配信イベント。ライブ配信・プレミア公開・アーカイブ動画を 1 単位として扱う。Holodex API の video エンティティ (type='stream') に対応。各 Stream は必ず 1 つの Channel に所属する。"
    },
    {
      "@language": "en",
      "@value": "A single streaming event that takes place on a Channel. Live broadcasts, premieres, and archived videos are all treated as one unit. Corresponds to the Holodex API video entity (type='stream'). Each Stream belongs to exactly one Channel."
    }
  ],
  "skos:altLabel": [
    {
      "@language": "ja",
      "@value": "放送"
    },
    {
      "@language": "ja",
      "@value": "ライブ配信"
    },
    {
      "@language": "ja",
      "@value": "動画"
    },
    {
      "@language": "en",
      "@value": "Broadcast"
    },
    {
      "@language": "en",
      "@value": "Live"
    },
    {
      "@language": "en",
      "@value": "Video"
    }
  ],
  "skos:related": [
    {
      "@id": "Channel"
    },
    {
      "@id": "Streamer"
    },
    {
      "@id": "Collaboration"
    },
    {
      "@id": "Clip"
    },
    {
      "@id": "Topic"
    }
  ],
  "skos:inScheme": {
    "@id": "VTuberDomain"
  },
  "dv:hub": "HUB_STREAM",
  "dv:business_key": "video_id",
  "dv:business_key_source": "Holodex video.id (= YouTube video ID)",
  "dv:belongs_to": "Channel (N:1, via LNK_STREAM_CHANNEL)"
}
