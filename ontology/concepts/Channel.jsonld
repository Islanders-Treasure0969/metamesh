{
  "@context": {
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "@base": "https://metamesh.dev/ontology/",
    "dv": "https://metamesh.dev/ext/dv/"
  },
  "@id": "Channel",
  "@type": "skos:Concept",
  "skos:prefLabel": [
    {
      "@language": "ja",
      "@value": "チャンネル"
    },
    {
      "@language": "en",
      "@value": "Channel"
    }
  ],
  "skos:definition": [
    {
      "@language": "ja",
      "@value": "YouTube・Twitch 等のプラットフォーム上で開設された、配信者が所有する個別の配信枠。1 人の Streamer がメインチャンネルに加え、歌枠・ゲーム実況・アーカイブ等の用途別サブチャンネルを複数所有することがある。Holodex API の channel エンティティに対応。"
    },
    {
      "@language": "en",
      "@value": "An individual streaming slot on a platform (YouTube/Twitch) owned by a streamer. A Streamer may own multiple Channels: a main channel plus sub-channels for songs, gameplay, archives, etc. Corresponds to the Holodex API channel entity."
    }
  ],
  "skos:altLabel": [
    {
      "@language": "ja",
      "@value": "YouTubeチャンネル"
    },
    {
      "@language": "ja",
      "@value": "サブチャンネル"
    },
    {
      "@language": "ja",
      "@value": "歌チャンネル"
    },
    {
      "@language": "en",
      "@value": "YouTube Channel"
    },
    {
      "@language": "en",
      "@value": "Sub-channel"
    }
  ],
  "skos:related": [
    {
      "@id": "Streamer"
    },
    {
      "@id": "Stream"
    },
    {
      "@id": "Organization"
    }
  ],
  "skos:inScheme": {
    "@id": "VTuberDomain"
  },
  "dv:hub": "HUB_CHANNEL",
  "dv:business_key": "channel_id",
  "dv:business_key_source": "Holodex channel.id (= YouTube UCxxxx)",
  "dv:owned_by": "Streamer (N:1, via LNK_STREAMER_CHANNEL)",
  "dv:channel_role_attribute": "main | song | gaming | archive | other"
}
