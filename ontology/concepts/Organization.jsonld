{
  "@context": {
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "@base": "https://metamesh.dev/ontology/",
    "dv": "https://metamesh.dev/ext/dv/"
  },
  "@id": "Organization",
  "@type": "skos:Concept",
  "skos:prefLabel": [
    {
      "@language": "ja",
      "@value": "事務所"
    },
    {
      "@language": "en",
      "@value": "Organization"
    }
  ],
  "skos:definition": [
    {
      "@language": "ja",
      "@value": "配信者が所属する VTuber 事務所・グループ。ホロライブ・にじさんじ・ぶいすぽっ! 等が該当。所属配信者にブランド・サポート・運営機能を提供する。個人勢の場合はいずれの Organization にも所属しない。"
    },
    {
      "@language": "en",
      "@value": "A VTuber agency or group that streamers belong to (e.g., Hololive, Nijisanji, VSPO!). Provides brand, operational support, and management to its members. Independent streamers do not belong to any Organization."
    }
  ],
  "skos:altLabel": [
    {
      "@language": "ja",
      "@value": "プロダクション"
    },
    {
      "@language": "ja",
      "@value": "グループ"
    },
    {
      "@language": "ja",
      "@value": "事務所"
    },
    {
      "@language": "ja",
      "@value": "ホロプロ"
    },
    {
      "@language": "ja",
      "@value": "ライバー事務所"
    },
    {
      "@language": "en",
      "@value": "Agency"
    },
    {
      "@language": "en",
      "@value": "Production"
    },
    {
      "@language": "en",
      "@value": "Group"
    }
  ],
  "skos:related": [
    {
      "@id": "Streamer"
    }
  ],
  "skos:inScheme": {
    "@id": "VTuberDomain"
  },
  "dv:hub": "HUB_ORGANIZATION",
  "dv:business_key": "org_name",
  "dv:business_key_source": "Holodex channel.org (e.g., 'Hololive', 'Nijisanji', 'Independents')"
}
