{
  "@context": {
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "@base": "https://metamesh.dev/ontology/",
    "dv": "https://metamesh.dev/ext/dv/"
  },
  "@id": "belongs_to_org",
  "@type": "owl:ObjectProperty",
  "skos:prefLabel": [
    {
      "@language": "ja",
      "@value": "事務所に所属する"
    },
    {
      "@language": "en",
      "@value": "belongs to organization"
    }
  ],
  "skos:definition": [
    {
      "@language": "ja",
      "@value": "配信者が VTuber 事務所に所属する関係。個人勢の場合は所属しない (関係なし)。Holodex channel.org 由来。"
    },
    {
      "@language": "en",
      "@value": "A streamer is affiliated with a VTuber agency. Independent streamers have no such relationship. Sourced from Holodex channel.org."
    }
  ],
  "rdfs:domain": {
    "@id": "Streamer"
  },
  "rdfs:range": {
    "@id": "Organization"
  },
  "skos:inScheme": {
    "@id": "VTuberDomain"
  },
  "dv:link": "LNK_STREAMER_ORG",
  "dv:cardinality": "N:1",
  "dv:optional": true
}
