{
  "@context": {
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "@base": "https://metamesh.dev/ontology/",
    "dv": "https://metamesh.dev/ext/dv/"
  },
  "@id": "derived_from",
  "@type": "owl:ObjectProperty",
  "skos:prefLabel": [
    {
      "@language": "ja",
      "@value": "から派生する"
    },
    {
      "@language": "en",
      "@value": "derived from"
    }
  ],
  "skos:definition": [
    {
      "@language": "ja",
      "@value": "切り抜きが元の配信から派生する関係。Holodex API では type='clip' の動画が type='stream' の動画を参照する形で表現される。"
    },
    {
      "@language": "en",
      "@value": "A clip is derived from an original stream. In the Holodex API, videos with type='clip' reference videos with type='stream'."
    }
  ],
  "rdfs:domain": {
    "@id": "Clip"
  },
  "rdfs:range": {
    "@id": "Stream"
  },
  "skos:inScheme": {
    "@id": "VTuberDomain"
  },
  "dv:link": "LNK_CLIP_STREAM",
  "dv:cardinality": "N:1"
}
