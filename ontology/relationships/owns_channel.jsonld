{
  "@context": {
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "@base": "https://metamesh.dev/ontology/",
    "dv": "https://metamesh.dev/ext/dv/"
  },
  "@id": "owns_channel",
  "@type": "owl:ObjectProperty",
  "skos:prefLabel": [
    {
      "@language": "ja",
      "@value": "チャンネルを所有する"
    },
    {
      "@language": "en",
      "@value": "owns channel"
    }
  ],
  "skos:definition": [
    {
      "@language": "ja",
      "@value": "配信者が YouTube/Twitch 等の配信枠を所有する関係。1 人の配信者がメインチャンネルとサブチャンネル (歌・ゲーム実況・アーカイブ等) を複数所有しうる。"
    },
    {
      "@language": "en",
      "@value": "A streamer owns a streaming slot on YouTube/Twitch, etc. A single streamer may own a main channel plus multiple sub-channels (songs, gameplay, archives)."
    }
  ],
  "rdfs:domain": {
    "@id": "Streamer"
  },
  "rdfs:range": {
    "@id": "Channel"
  },
  "skos:inScheme": {
    "@id": "VTuberDomain"
  },
  "dv:link": "LNK_STREAMER_CHANNEL",
  "dv:cardinality": "1:N",
  "dv:role_attribute": "channel_role (main | song | gaming | archive | other)"
}
