{
  "@context": {
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "@base": "https://metamesh.dev/ontology/",
    "dv": "https://metamesh.dev/ext/dv/"
  },
  "@id": "categorized_as",
  "@type": "owl:ObjectProperty",
  "skos:prefLabel": [
    {
      "@language": "ja",
      "@value": "カテゴリに分類される"
    },
    {
      "@language": "en",
      "@value": "categorized as"
    }
  ],
  "skos:definition": [
    {
      "@language": "ja",
      "@value": "配信がジャンル/テーマに分類される関係。1 配信に複数の Topic が紐づくことがある。Holodex video.topic_id 由来。"
    },
    {
      "@language": "en",
      "@value": "A stream is classified by genre/theme. A single stream may carry multiple topics. Sourced from Holodex video.topic_id."
    }
  ],
  "rdfs:domain": {
    "@id": "Stream"
  },
  "rdfs:range": {
    "@id": "Topic"
  },
  "skos:inScheme": {
    "@id": "VTuberDomain"
  },
  "dv:link": "LNK_STREAM_TOPIC",
  "dv:cardinality": "N:M"
}
