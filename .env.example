# Copy this file to `.env` (gitignored) and fill in real values.
# `scripts/validate_holodex.py` reads HOLODEX_API_KEY from the environment
# OR from this file (env var takes precedence).
#
# Get a free Holodex API key at https://holodex.net (Account Settings → API).

# --- Pattern A: raw value (simplest) -----------------------------------------
HOLODEX_API_KEY=your-key-here

# --- Pattern B: 1Password CLI reference (recommended; never store the key
# in plaintext on disk). Requires the `op` CLI installed and signed in.
# The script detects values starting with `op://` and resolves them at runtime
# via `op read`.
# HOLODEX_API_KEY=op://Personal/Holodex/credential

# Optional overrides for the validation script:
# HOLODEX_VALIDATE_ORG=Hololive       # which org to sample from
# HOLODEX_VALIDATE_CHANNELS=5         # how many channels to fetch
# HOLODEX_VALIDATE_VIDEOS=10          # how many videos per channel
